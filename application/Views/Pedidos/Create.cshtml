@model application.Dtos.CrearPedidoDto

@{
    ViewData["Title"] = "Crear Pedido";
    var meseros = ViewBag.Meseros as List<application.Models.UsuarioModel>;
    var mesas = ViewBag.Mesas as List<application.Models.MesaModel>;
    var platos = ViewBag.Platos as List<application.Models.PlatoModel>;
}

<div style="max-width:1100px; margin:30px auto; background:#fff; border-radius:16px; padding:30px; box-shadow:0 4px 18px rgba(0,0,0,0.08);">

    <div class="page-top pedidos-create-top" style="margin-bottom:25px;">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Crear Pedido</h1>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div style="background:#ffe5e5; color:#a30000; padding:12px 15px; border-radius:10px; margin-bottom:20px;">
            @ViewBag.Error
        </div>
    }

    <form asp-action="Create" method="post" id="pedidoForm">
        <div asp-validation-summary="ModelOnly" style="color:#a30000; margin-bottom:12px;"></div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:25px;">

            <div>
                <label style="display:block; margin-bottom:8px; font-weight:bold;">Mesero</label>
                <select asp-for="meseroId" required
                        style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px;">
                    <option value="">Seleccione</option>
                    @if (meseros != null)
                    {
                        @foreach (var m in meseros)
                        {
                            <option value="@m.id">@m.nombre</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label style="display:block; margin-bottom:8px; font-weight:bold;">DNI Cliente</label>
                <input asp-for="dniCliente" required
                        type="text"
                        placeholder="Ej: 72599882"
                        style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px;" />
            </div>

            <div>
                <label style="display:block; margin-bottom:8px; font-weight:bold;">Mesa</label>
                <select asp-for="mesaId" required
                        style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px;">
                    <option value="">Seleccione</option>
                    @if (mesas != null)
                    {
                        @foreach (var m in mesas)
                        {
                            <option value="@m.id">Mesa @m.id - Piso @m.numeroPiso</option>
                        }
                    }
                </select>
            </div>

            <div style="grid-column:1 / span 2;">
                <label style="display:block; margin-bottom:8px; font-weight:bold;">Estado</label>
                <input asp-for="estado" readonly
                       style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px; background:#f5f5f5;" />
            </div>
        </div>

        <hr style="margin:25px 0;" />

        <h4 style="margin-bottom:20px;">Agregar Plato</h4>

        <div style="display:grid; grid-template-columns:2fr 1fr auto; gap:15px; align-items:end; margin-bottom:25px;">
            <div>
                <label style="display:block; margin-bottom:8px; font-weight:bold;">Plato</label>
                <select id="platoSelect"
                        style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px;">
                    <option value="">Seleccione</option>
                    @if (platos != null)
                    {
                        @foreach (var p in platos)
                        {
                            <option value="@p.id"
                                    data-nombre="@p.nombre"
                                    data-precio="@p.precio">
                                @p.nombre - S/ @p.precio
                            </option>
                        }
                    }
                </select>
            </div>

            <div>
                <label style="display:block; margin-bottom:8px; font-weight:bold;">Cantidad</label>
                <input type="number" id="cantidadInput" min="1" value="1"
                       style="width:100%; padding:12px; border:1px solid #ccc; border-radius:10px;" />
            </div>

            <div>
                <button type="button" onclick="agregarPlato()"
                        style="padding:12px 22px; border:none; border-radius:10px; background:#222; color:white; cursor:pointer;">
                    Agregar
                </button>
            </div>
        </div>

        <div style="border:1px solid #ddd; border-radius:14px; overflow:hidden; margin-bottom:20px;">
            <table style="width:100%; border-collapse:collapse;">
                <thead style="background:#f7f7f7;">
                    <tr>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #ddd;">Plato</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #ddd;">Cantidad</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #ddd;">Precio</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #ddd;">Subtotal</th>
                        <th style="padding:14px; text-align:center; border-bottom:1px solid #ddd;">Acci�n</th>
                    </tr>
                </thead>
                <tbody id="detalleBody">
                    <tr id="filaVacia">
                        <td colspan="5" style="padding:18px; text-align:center; color:#777;">
                            No has agregado platos todav�a.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div style="display:flex; justify-content:flex-end; margin-bottom:25px;">
            <div style="font-size:22px; font-weight:bold;">
                Total: S/ <span id="totalGeneral">0.00</span>
            </div>
        </div>

        <div style="display:flex; gap:12px;">
            <button type="submit"
                    style="padding:12px 24px; border:none; border-radius:10px; background:#111; color:white; cursor:pointer;">
                Crear Pedido
            </button>

            <a asp-action="Index"
               style="padding:12px 24px; border-radius:10px; background:#e9e9e9; color:#222; text-decoration:none;">
                Volver
            </a>
        </div>
    </form>
</div>

<script>
    function agregarPlato() {
        const select = document.getElementById('platoSelect');
        const cantidadInput = document.getElementById('cantidadInput');
        const tbody = document.getElementById('detalleBody');
        const filaVacia = document.getElementById('filaVacia');

        if (!select.value) {
            alert('Selecciona un plato');
            return;
        }

        const cantidad = parseInt(cantidadInput.value);
        if (isNaN(cantidad) || cantidad <= 0) {
            alert('Ingresa una cantidad v�lida');
            return;
        }

        const option = select.options[select.selectedIndex];
        const platoId = option.value;
        const nombre = option.getAttribute('data-nombre');
        const precio = parseFloat(option.getAttribute('data-precio'));
        const subtotal = precio * cantidad;

        if (filaVacia) {
            filaVacia.remove();
        }

        const row = document.createElement('tr');
        row.innerHTML = `
            <td style="padding:14px; border-bottom:1px solid #eee;">
                ${nombre}
                <input type="hidden" name="platoIds" value="${platoId}" />
            </td>
            <td style="padding:14px; border-bottom:1px solid #eee;">
                ${cantidad}
                <input type="hidden" name="cantidades" value="${cantidad}" />
            </td>
            <td style="padding:14px; border-bottom:1px solid #eee;">
                ${precio.toFixed(2)}
                <input type="hidden" name="precios" value="${precio}" />
            </td>
            <td class="subtotal" style="padding:14px; border-bottom:1px solid #eee;">
                ${subtotal.toFixed(2)}
            </td>
            <td style="padding:14px; text-align:center; border-bottom:1px solid #eee;">
                <button type="button" onclick="eliminarFila(this)"
                        style="padding:8px 14px; border:none; border-radius:8px; background:#d9534f; color:white; cursor:pointer;">
                    Quitar
                </button>
            </td>
        `;

        tbody.appendChild(row);
        recalcularTotal();

        select.selectedIndex = 0;
        cantidadInput.value = 1;
    }

    function eliminarFila(btn) {
        const fila = btn.closest('tr');
        fila.remove();

        const tbody = document.getElementById('detalleBody');
        if (tbody.querySelectorAll('tr').length === 0) {
            tbody.innerHTML = `
                <tr id="filaVacia">
                    <td colspan="5" style="padding:18px; text-align:center; color:#777;">
                        No has agregado platos todav�a.
                    </td>
                </tr>
            `;
        }

        recalcularTotal();
    }

    function recalcularTotal() {
        const subtotales = document.querySelectorAll('.subtotal');
        let total = 0;

        subtotales.forEach(s => {
            total += parseFloat(s.textContent);
        });

        document.getElementById('totalGeneral').textContent = total.toFixed(2);
    }

    document.getElementById('pedidoForm').addEventListener('submit', function (e) {
        const filasReales = document.querySelectorAll('#detalleBody tr');
        const filaVacia = document.getElementById('filaVacia');

        if (filasReales.length === 0 || filaVacia) {
            e.preventDefault();
            alert('Debes agregar al menos un plato');
        }
    });
</script>