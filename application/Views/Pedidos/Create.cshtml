@model application.Models.PedidoModel
@{
    ViewData["Title"] = "Nuevo Pedido";
}

<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <div class="diamond"></div>
            <h1 class="page-title">Nuevo Pedido</h1>
        </div>
    </div>

    <form asp-action="Create" method="post" class="form-panel">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="field-group">
                <label asp-for="usuarioId">Usuario ID</label>
                <input asp-for="usuarioId" type="number" class="form-input" />
                <span asp-validation-for="usuarioId" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="mesaId">Mesa ID</label>
                <input asp-for="mesaId" type="number" class="form-input" />
                <span asp-validation-for="mesaId" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="fecha">Fecha</label>
                <input asp-for="fecha" type="date" class="form-input" />
                <span asp-validation-for="fecha" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="total">Total</label>
                <input asp-for="total" type="number" step="0.01" class="form-input" />
                <span asp-validation-for="total" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="estado">Estado</label>
                <select asp-for="estado" class="form-select">
                    <option value="Pendiente">Pendiente</option>
                    <option value="En proceso">En proceso</option>
                    <option value="Entregado">Entregado</option>
                </select>
                <span asp-validation-for="estado" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Guardar</button>
            <a asp-action="Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>
