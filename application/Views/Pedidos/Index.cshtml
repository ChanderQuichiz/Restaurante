@model List<PedidosPagosMVC.Models.Pedido>
@{
    ViewData["Title"] = "Pedidos";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <div class="diamond"></div>
            <h1 class="page-title">Gestión de Pedidos</h1>
        </div>
        <a asp-action="Create" class="primary-btn">Nuevo Pedido</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" value="@Context.Request.Query["buscar"]" placeholder="Buscar por cliente o estado" />
        </div>
        <div class="filter-box">
            <label>Estado</label>
            <select class="select-pill" name="buscar">
                <option value="">Todos</option>
                <option value="Pendiente">Pendiente</option>
                <option value="En proceso">En proceso</option>
                <option value="Entregado">Entregado</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Fecha</label>
            <input type="date" class="input-pill" disabled />
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var statusClass = item.Estado == "Entregado" ? "status-green" : item.Estado == "En proceso" ? "status-yellow" : "status-red";
                        <tr>
                            <td>P-@item.Id.ToString("000")</td>
                            <td>@item.Cliente</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>S/ @item.Monto.ToString("0.00")</td>
                            <td class="@statusClass">@item.Estado</td>
                            <td>
                              <div class="action-buttons">
                                                                <a href="/Pedidos/Edit/@item.Id" class="action-btn" title="Editar">
                                  <img src="assets/editar.png">
                                </a>
                                                                <form action="/Pedidos/Delete/@item.Id" method="post" class="action-form" onsubmit="return confirm('¿Está seguro que desea eliminar este pedido?');">
                                                                    <button type="submit" class="action-btn" title="Eliminar">
                                    <img src="assets/eliminar.png">
                                  </button>
                                </form>
                              </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-box">No se encontraron pedidos.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        <div class="page-pill">‹</div>
        <div class="page-pill active">1</div>
        <div class="page-pill">2</div>
        <div class="page-pill">3</div>
        <div class="page-pill">›</div>
    </div>
</div>
