@model application.Dtos.PedidoVM

@{
    ViewData["Title"] = "Gestión de Pedidos";
}

<div class="page-top pedidos-page-top">
    <div class="page-title-wrap">
        <img src="/assets/rombo.png" class="page-mark">
        <h1 class="page-title">Gestión de Pedidos</h1>
    </div>
</div>

<form method="get" asp-action="Index">
    <div class="pedidos-filters-row">
        <div class="pedidos-filter-item pedidos-filter-buscar">
            <label class="pedidos-filter-label">Buscar</label>
            <input type="text"
                   name="buscar"
                   value="@(Model.buscar ?? string.Empty)"
                   placeholder="Buscar por DNI"
                   class="pedidos-filter-input" />
        </div>
        <div class="pedidos-filter-item pedidos-filter-estado">
            <label class="pedidos-filter-label">Estado</label>
            <select name="estado"
                    class="pedidos-filter-select">
                <option value="">Todos</option>
                @foreach (var estado in Enum.GetValues<EstadoPedidoEnum>())
                {
                    if (Model.estado == estado)
                    {
                        <option value="@estado" selected>@(estado == EstadoPedidoEnum.EnProceso ? "En proceso" : estado.ToString())</option>
                    }
                    else
                    {
                        <option value="@estado">@(estado == EstadoPedidoEnum.EnProceso ? "En proceso" : estado.ToString())</option>
                    }
                }
            </select>
        </div>
        <div class="pedidos-filter-item pedidos-filter-fecha">
            <label class="pedidos-filter-label">Fecha</label>
            <input type="date"
                   name="fecha"
                   value="@(Model.fecha?.ToString("yyyy-MM-dd") ?? string.Empty)"
                   class="pedidos-filter-input" />
        </div>
        <div class="pedidos-filter-actions">
            <button type="submit" class="pedidos-filter-btn">
                Filtrar
            </button>

            
            <a asp-action="Create" class="pedidos-filter-btn pedidos-filter-link-btn">
                Nuevo Pedido
            </a>
        </div>
    </div>
    

</form>

<div class="pedidos-table-card">

    
    <table class="pedidos-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Mesero</th>
                <th>DNI Cliente</th>
                <th>Mesa</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.pedidos != null && Model.pedidos.Any())
            {
                @foreach (var item in Model.pedidos)
                {
                    <tr>
                        <td>@item.id</td>
                        <td>@item.meseroNombre</td>
                        <td>@item.dniCliente</td>
                        <td>Mesa @item.mesaId</td>
                        <td>@(item.estado == EstadoPedidoEnum.EnProceso ? "En proceso" : item.estado.ToString())</td>
                        <td>@item.fecha.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>S/ @item.total.ToString("0.00")</td>
                        <td class="pedidos-accion-cell">
                            <!-- BOTÓN DETALLE FUNCIONAL -->
                            <a asp-controller="Pedidos"
                               asp-action="Detalle"
                               asp-route-id="@item.id"
                               class="pedidos-table-detail-btn">
                                Detalle
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="pedidos-empty">
                        No se encontraron pedidos.
                    </td>
                </tr>
            }
        </tbody>
    </table>
    

</div>

<div class="pagination-mock">
    @if (Model.page > 1)
    {
        <a asp-action="Index"
           asp-route-page="@(Model.page - 1)"
           asp-route-buscar="@(Model.buscar ?? string.Empty)"
           asp-route-estado="@(Model.estado?.ToString() ?? string.Empty)"
           asp-route-fecha="@(Model.fecha?.ToString("yyyy-MM-dd") ?? string.Empty)"
           class="page-pill">‹</a>
    }
    else
    {
        <div class="page-pill">‹</div>
    }

    
    @for (int i = 1; i <= Model.totalPages; i++)
    {
        if (i == Model.page)
        {
            <a asp-action="Index"
               asp-route-page="@i"
               asp-route-buscar="@(Model.buscar ?? string.Empty)"
               asp-route-estado="@(Model.estado?.ToString() ?? string.Empty)"
               asp-route-fecha="@(Model.fecha?.ToString("yyyy-MM-dd") ?? string.Empty)"
               class="page-pill active">@i</a>
        }
        else
        {
            <a asp-action="Index"
               asp-route-page="@i"
               asp-route-buscar="@(Model.buscar ?? string.Empty)"
               asp-route-estado="@(Model.estado?.ToString() ?? string.Empty)"
               asp-route-fecha="@(Model.fecha?.ToString("yyyy-MM-dd") ?? string.Empty)"
               class="page-pill">@i</a>
        }
    }

    @if (Model.page < Model.totalPages)
    {
        <a asp-action="Index"
           asp-route-page="@(Model.page + 1)"
           asp-route-buscar="@(Model.buscar ?? string.Empty)"
           asp-route-estado="@(Model.estado?.ToString() ?? string.Empty)"
           asp-route-fecha="@(Model.fecha?.ToString("yyyy-MM-dd") ?? string.Empty)"
           class="page-pill">›</a>
    }
    else
    {
        <div class="page-pill">›</div>
    }
    

</div>
