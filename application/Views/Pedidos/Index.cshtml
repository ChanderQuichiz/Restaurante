@model List<application.Dtos.PedidoDto>

@{
    ViewData["Title"] = "Gestión de Pedidos";

    var buscar = Context.Request.Query["buscar"].ToString();
    var estadoSeleccionado = Context.Request.Query["estado"].ToString();
    var fechaSeleccionada = Context.Request.Query["fecha"].ToString();
}

<div class="page-top pedidos-page-top">
    <div class="page-title-wrap">
        <img src="/assets/rombo.png" class="page-mark">
        <h1 class="page-title">Gestión de Pedidos</h1>
    </div>
</div>

<form method="get" asp-action="Index">
    <div class="pedidos-filters-row">
        <div class="pedidos-filter-item pedidos-filter-buscar">
            <label class="pedidos-filter-label">Buscar</label>
            <input type="text"
                   name="buscar"
                   value="@buscar"
                   placeholder="Buscar por DNI"
                   class="pedidos-filter-input" />
        </div>
        <div class="pedidos-filter-item pedidos-filter-estado">
            <label class="pedidos-filter-label">Estado</label>
            <select name="estado"
                    class="pedidos-filter-select">
                <option value="" selected="@(string.IsNullOrEmpty(estadoSeleccionado))">Todos</option>
                <option value="Pendiente" selected="@(estadoSeleccionado == "Pendiente")">Pendiente</option>
                <option value="En proceso" selected="@(estadoSeleccionado == "En proceso")">En proceso</option>
                <option value="Entregado" selected="@(estadoSeleccionado == "Entregado")">Entregado</option>
            </select>
        </div>
        <div class="pedidos-filter-item pedidos-filter-fecha">
            <label class="pedidos-filter-label">Fecha</label>
            <input type="date"
                   name="fecha"
                   value="@fechaSeleccionada"
                   class="pedidos-filter-input" />
        </div>
        <div class="pedidos-filter-actions">
            <button type="submit" class="pedidos-filter-btn">
                Filtrar
            </button>

            <a asp-action="Create" class="pedidos-filter-btn pedidos-filter-link-btn">
                Nuevo Pedido
            </a>
        </div>
    </div>
</form>
<div class="pedidos-table-card">

    <table class="pedidos-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Mesero</th>
                <th>DNI Cliente</th>
                <th>Mesa</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.id</td>
                        <td>@item.meseroNombre</td>
                        <td>@item.dniCliente</td>
                        <td>Mesa @item.mesaId</td>
                        <td>@item.estado</td>
                        <td>
                            @item.fecha.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>
                            S/ @item.total.ToString("0.00")
                        </td>
                        <td>
                            <button type="button" class="pedidos-table-detail-btn">Detalle</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="pedidos-empty">
                        No se encontraron pedidos.
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>