@model PedidosPagosMVC.Models.Pago
@{
    ViewData["Title"] = "Editar Pago";
}

<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <div class="diamond"></div>
            <h1 class="page-title">Editar Pago</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="form-panel">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="form-grid">
            <div class="field-group">
                <label asp-for="PedidoId">Pedido ID</label>
                <input asp-for="PedidoId" type="number" class="form-input" />
                <span asp-validation-for="PedidoId" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="Monto">Monto</label>
                <input asp-for="Monto" type="number" step="0.01" class="form-input" />
                <span asp-validation-for="Monto" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="Fecha">Fecha</label>
                <input asp-for="Fecha" type="date" class="form-input" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="Metodo">Método</label>
                <select asp-for="Metodo" class="form-select">
                    <option value="">-- Seleccionar --</option>
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Transferencia">Transferencia</option>
                </select>
                <span asp-validation-for="Metodo" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Actualizar</button>
            <a asp-action="Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
