@model application.Models.PagoModel
@{
    ViewData["Title"] = "Nuevo Pago";
}

<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <div class="diamond"></div>
            <h1 class="page-title">Nuevo Pago</h1>
        </div>
    </div>

    <form asp-action="Create" method="post" class="form-panel">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="field-group">
                <label asp-for="pedidoId">Pedido ID</label>
                <input asp-for="pedidoId" class="form-input" />
                <span asp-validation-for="pedidoId" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="usuarioId">Usuario ID</label>
                <input asp-for="usuarioId" class="form-input" />
                <span asp-validation-for="usuarioId" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="monto">Monto</label>
                <input asp-for="monto" type="number" step="0.01" class="form-input" />
                <span asp-validation-for="monto" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="fecha">Fecha</label>
                <input asp-for="fecha" type="date" class="form-input" />
                <span asp-validation-for="fecha" class="text-danger"></span>
            </div>
            <div class="field-group">
                <label asp-for="metodoPago">Método</label>
                <select asp-for="metodoPago" class="form-select">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Transferencia">Transferencia</option>
                </select>
                <span asp-validation-for="metodoPago" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Guardar</button>
            <a asp-action="Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>
