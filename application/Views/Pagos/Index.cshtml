@model List<PedidosPagosMVC.Models.Pago>
@{
    ViewData["Title"] = "Pagos";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <div class="diamond"></div>
            <h1 class="page-title">Gestión de Pagos</h1>
        </div>
        <a asp-action="Create" class="primary-btn">Nuevo Pago</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" value="@Context.Request.Query["buscar"]" placeholder="Buscar por ID de pedido" />
        </div>
        <div class="filter-box">
            <label>Método</label>
            <select class="select-pill" disabled>
                <option>Todos</option>
                <option>Efectivo</option>
                <option>Tarjeta</option>
                <option>Transferencia</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Fecha</label>
            <input type="date" class="input-pill" disabled />
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pedido</th>
                    <th>Monto</th>
                    <th>Fecha</th>
                    <th>Método</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>PG-@item.Id.ToString("000")</td>
                            <td>P-@item.PedidoId.ToString("000")</td>
                            <td>S/ @item.Monto.ToString("0.00")</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td class="status-green">@item.Metodo</td>
                            <td>
                              <div class="action-buttons">
                                                                <a href="/Pagos/Edit/@item.Id" class="action-btn" title="Editar">
                                  <img src="assets/editar.png">
                                </a>
                                                                <form action="/Pagos/Delete/@item.Id" method="post" class="action-form" onsubmit="return confirm('¿Está seguro que desea eliminar este pago?');">
                                                                    <button type="submit" class="action-btn" title="Eliminar">
                                    <img src="assets/eliminar.png">
                                  </button>
                                </form>
                              </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="empty-box">No se encontraron pagos.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        <div class="page-pill">‹</div>
        <div class="page-pill active">1</div>
        <div class="page-pill">2</div>
        <div class="page-pill">3</div>
        <div class="page-pill">›</div>
    </div>
</div>
