@model List<application.Models.PagoModel>

@{
    ViewData["Title"] = "Pagos";

    var buscar = Context.Request.Query["buscar"].ToString();
    var metodoSel = Context.Request.Query["metodo"].ToString();
    var fechaSel = Context.Request.Query["fecha"].ToString();
}

<div class="content-card">
    <div class="page-top pedidos-page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Pagos</h1>
        </div>
    </div>

    <form method="get">
        <div class="pedidos-filters-row">
            <div class="pedidos-filter-item pedidos-filter-buscar">
                <label class="pedidos-filter-label">Buscar</label>
                <input type="text"
                       name="buscar"
                       class="pedidos-filter-input"
                       value="@buscar"
                       placeholder="Buscar por DNI del cliente" />
            </div>

            <div class="pedidos-filter-item pedidos-filter-estado">
                <label class="pedidos-filter-label">Método</label>
                <select class="pedidos-filter-select" name="metodo">
                    <option value="" selected="@(string.IsNullOrEmpty(metodoSel))">Todos</option>
                    <option value="Efectivo" selected="@(metodoSel == "Efectivo")">Efectivo</option>
                    <option value="Tarjeta" selected="@(metodoSel == "Tarjeta")">Tarjeta</option>
                    <option value="Transferencia" selected="@(metodoSel == "Transferencia")">Transferencia</option>
                </select>
            </div>

            <div class="pedidos-filter-item pedidos-filter-fecha">
                <label class="pedidos-filter-label">Fecha</label>
            <input type="date"
                   class="pedidos-filter-input"
                   name="fecha"
                   value="@fechaSel" />
            </div>

            <div class="pedidos-filter-actions">
                <button type="submit" class="pedidos-filter-btn">Filtrar</button>
                <a asp-action="Create" asp-route-pedidoId="1" class="pedidos-filter-btn pedidos-filter-link-btn">Nuevo Pago</a>
            </div>
        </div>
    </form>

    <div class="pedidos-table-card">
        <table class="pedidos-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pedido</th>
                    <th>Cajero</th>
                    <th>Monto</th>
                    <th>Fecha</th>
                    <th>Método</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.id</td>
                            <td>@item.pedidoId</td>
                            <td>@(item.Usuario != null ? item.Usuario.nombre : "-")</td>
                            <td>S/ @item.monto.ToString("0.00")</td>
                            <td>@item.fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="status-green">@item.metodoPago</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="pedidos-empty">No se encontraron pagos.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>