@model application.Dtos.PagoVM

@{
    ViewData["Title"] = "Pagos";
}

<div class="content-card">
    <div class="page-top pedidos-page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Pagos</h1>
        </div>
    </div>

    <form method="get">
        <div class="pedidos-filters-row">
            <div class="pedidos-filter-item pedidos-filter-buscar">
                <label class="pedidos-filter-label">Buscar</label>
                <input type="text"
                       name="buscar"
                       class="pedidos-filter-input"
                       value="@(Model.filtros.buscar ?? string.Empty)"
                      placeholder="Buscar por pedido" />
            </div>

            <div class="pedidos-filter-item pedidos-filter-estado">
                <label class="pedidos-filter-label">Método</label>
                <select class="pedidos-filter-select" name="metodo">
                    <option value="">Todos</option>
                    <option value="Efectivo" selected="@(Model.filtros.metodo == "Efectivo")">Efectivo</option>
                    <option value="Tarjeta" selected="@(Model.filtros.metodo == "Tarjeta")">Tarjeta</option>
                    <option value="Transferencia" selected="@(Model.filtros.metodo == "Transferencia")">Transferencia</option>
                </select>
            </div>

            <div class="pedidos-filter-item pedidos-filter-fecha">
                <label class="pedidos-filter-label">Fecha</label>
                <input type="date"
                       class="pedidos-filter-input"
                       name="fecha"
                       value="@(Model.filtros.fecha.HasValue ? Model.filtros.fecha.Value.ToString("yyyy-MM-dd") : string.Empty)" />
            </div>

            <div class="pedidos-filter-actions">
                <button type="submit" class="pedidos-filter-btn">Filtrar</button>
                <a asp-action="Create" class="pedidos-filter-btn pedidos-filter-link-btn">Nuevo Pago</a>
            </div>
        </div>
    </form>

    <div class="pedidos-table-card">
        <table class="pedidos-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pedido</th>
                    <th>Cajero</th>
                    <th>Monto</th>
                    <th>Fecha</th>
                    <th>Método</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.pagos.Any())
                {
                    @foreach (var item in Model.pagos)
                    {
                        <tr>
                            <td>@item.id</td>
                            <td>@item.pedidoId</td>
                            <td>@(string.IsNullOrWhiteSpace(item.cajeroNombre) ? "-" : item.cajeroNombre)</td>
                            <td>S/ @item.monto.ToString("0.00")</td>
                            <td>@item.fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="status-green">@item.metodoPago</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="pedidos-empty">No se encontraron pagos.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        @if (Model.page > 1)
        {
            <a asp-action="Index"
               asp-route-page="@(Model.page - 1)"
               asp-route-buscar="@(Model.filtros.buscar ?? string.Empty)"
               asp-route-metodo="@(Model.filtros.metodo ?? string.Empty)"
               asp-route-fecha="@(Model.filtros.fecha.HasValue ? Model.filtros.fecha.Value.ToString("yyyy-MM-dd") : string.Empty)"
               class="page-pill">‹</a>
        }
        else
        {
            <div class="page-pill">‹</div>
        }

        @for (int i = 1; i <= Model.totalPages; i++)
        {
            if (i == Model.page)
            {
                <a asp-action="Index"
                   asp-route-page="@i"
                   asp-route-buscar="@(Model.filtros.buscar ?? string.Empty)"
                   asp-route-metodo="@(Model.filtros.metodo ?? string.Empty)"
                   asp-route-fecha="@(Model.filtros.fecha.HasValue ? Model.filtros.fecha.Value.ToString("yyyy-MM-dd") : string.Empty)"
                   class="page-pill active">@i</a>
            }
            else
            {
                <a asp-action="Index"
                   asp-route-page="@i"
                   asp-route-buscar="@(Model.filtros.buscar ?? string.Empty)"
                   asp-route-metodo="@(Model.filtros.metodo ?? string.Empty)"
                   asp-route-fecha="@(Model.filtros.fecha.HasValue ? Model.filtros.fecha.Value.ToString("yyyy-MM-dd") : string.Empty)"
                   class="page-pill">@i</a>
            }
        }

        @if (Model.page < Model.totalPages)
        {
            <a asp-action="Index"
               asp-route-page="@(Model.page + 1)"
               asp-route-buscar="@(Model.filtros.buscar ?? string.Empty)"
               asp-route-metodo="@(Model.filtros.metodo ?? string.Empty)"
               asp-route-fecha="@(Model.filtros.fecha.HasValue ? Model.filtros.fecha.Value.ToString("yyyy-MM-dd") : string.Empty)"
               class="page-pill">›</a>
        }
        else
        {
            <div class="page-pill">›</div>
        }
    </div>
</div>