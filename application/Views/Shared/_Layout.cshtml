<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - application</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Fuente -->
    <link href="https://fonts.googleapis.com/css2?family=Holtwood+One+SC&display=swap" rel="stylesheet" />

    <!-- (Opcional) estilos del proyecto -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="flex min-h-screen [font-family:'Holtwood_One_SC',serif]">

    <!-- ═══════════════════════ SIDEBAR ═══════════════════════ -->
    <aside class="w-[308px] min-w-[308px] bg-[#d82929] flex flex-col">

        <!-- Logo -->
        <div class="px-3 pt-2 h-[285px] flex items-center justify-center">
            <img src="/assets/logo.png" class="w-full block">
        </div>

        <!-- Navegación -->
        <nav class="flex-1">

            <a asp-controller="Mesa" asp-action="Index"
               class="flex items-center gap-3 px-5 py-4 text-[#fff7d7] no-underline bg-black/15">
                <img src="/assets/mesas.png" class="w-9 h-9 object-contain shrink-0">
                <span class="nav-item-title">MESAS</span>
            </a>

            <a asp-controller="Platos" asp-action="Index"
               class="flex items-center gap-3 px-5 py-4 text-[#fff7d7] no-underline">
                <img src="/assets/platos.png" class="w-9 h-9 object-contain shrink-0">
                <span class="nav-item-title">PLATOS</span>
            </a>

            <a asp-controller="Pedidos" asp-action="Index"
               class="flex items-center gap-3 px-5 py-4 text-[#fff7d7] no-underline">
                <img src="/assets/pedidos.png" class="w-9 h-9 object-contain shrink-0">
                <span class="nav-item-title">PEDIDOS</span>
            </a>

            <a asp-controller="Pagos" asp-action="Index"
               class="flex items-center gap-3 px-5 py-4 text-[#fff7d7] no-underline">
                <img src="/assets/pagos.png" class="w-9 h-9 object-contain shrink-0">
                <span class="nav-item-title">PAGOS</span>
            </a>

        </nav>

        <!-- Usuario -->
        <div class="flex items-center gap-3 px-5 py-6 border-t border-white/20">
            <img src="/assets/profile.png" class="w-14 h-14 rounded-full object-cover shrink-0">
            <div>
                <p class="m-0 nav-user-name">linguini</p>
                <p class="m-0 nav-user-role">MESERO</p>
            </div>
        </div>

    </aside>


    <!-- ═══════════════════════ CONTENIDO PRINCIPAL ═══════════════════════ -->
    <main class="flex-1 bg-[#fff7d7] px-11 py-9 flex flex-col gap-7">

        @RenderBody()

    </main>


    <!-- Scripts (del primer layout) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>