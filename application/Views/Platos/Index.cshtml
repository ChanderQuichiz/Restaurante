@model application.Dtos.PlatoVM

@{
    ViewData["Title"] = "Platos";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Platos</h1>
        </div>
        <a href="/Platos/Create" class="primary-btn">Nuevo plato</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" placeholder="Buscar por nombre" />
        </div>
        <div class="filter-box">
            <label>Categoría</label>
            <select class="select-pill" name="categoria">
                <option>Todos</option>
                <option>Entrada</option>
                <option>Fondo</option>
                <option>Bebida</option>
                <option>Postre</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Estado</label>
            <select class="select-pill" name="estado">
                <option>Todos</option>
                <option>ACTIVO</option>
                <option>INACTIVO</option>
                <option>AGOTADO</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plato in Model.platos){
                    <tr>
                    <td>@plato.id</td>
                    <td>@plato.nombre</td>
                    <td>S/ @plato.precio.ToString("F2")</td>
                    <td>@plato.categoria</td>
                    <td class="status-green">@plato.estado</td>
                    <td>
                        <div class="action-buttons">
                              <div class="action-buttons">
                            <a href="@Url.Action("Edit", "Platos", new { id = plato.id })" class="action-btn" title="Editar">  
                                <img src="/assets/editar.png" alt="Editar">
                            </a>
                            <a href="@Url.Action("Delete", "Platos", new { id = plato.id })" class="action-btn form-delete-btn" title="Eliminar">
                                <img src="/assets/eliminar.png" alt="Eliminar">
                            </a>
                        
                        </div>
                    </td>
                </tr>
                }
                
        
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        @if (Model.page > 1)
        {
            <a asp-action="Index" asp-route-page="@(Model.page - 1)" class="page-pill">‹</a>
        }
        else
        {
            <div class="page-pill">‹</div>
        }

        @for (int i = 1; i <= Model.totalPages; i++)
        {
            if (i == Model.page)
            {
                <a asp-action="Index" asp-route-page="@i" class="page-pill active">@i</a>
            }
            else
            {
                <a asp-action="Index" asp-route-page="@i" class="page-pill">@i</a>
            }
        }

        @if (Model.page < Model.totalPages)
        {
            <a asp-action="Index" asp-route-page="@(Model.page + 1)" class="page-pill">›</a>
        }
        else
        {
            <div class="page-pill">›</div>
        }
    </div>
</div>