@{
    ViewData["Title"] = "Platos";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Platos</h1>
        </div>
        <a href="/Platos/Create" class="primary-btn">Nuevo plato</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" placeholder="Buscar por nombre" />
        </div>
        <div class="filter-box">
            <label>Categoría</label>
            <select class="select-pill" name="categoria">
                <option>Todos</option>
                <option>Entrada</option>
                <option>Fondo</option>
                <option>Bebida</option>
                <option>Postre</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Estado</label>
            <select class="select-pill" name="estado">
                <option>Todos</option>
                <option>ACTIVO</option>
                <option>INACTIVO</option>
                <option>AGOTADO</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>PL-001</td>
                    <td>Lomo saltado</td>
                    <td>S/ 24.90</td>
                    <td>Fondo</td>
                    <td class="status-green">ACTIVO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Platos/Edit/1" class="action-btn" title="Editar">
                                <img src="/assets/editar.png" alt="Editar">
                            </a>
                            <form action="/Platos/Delete/1" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar este plato?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png" alt="Eliminar">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>PL-002</td>
                    <td>Inka Cola</td>
                    <td>S/ 6.50</td>
                    <td>Bebida</td>
                    <td class="status-yellow">AGOTADO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Platos/Edit/2" class="action-btn" title="Editar">
                                <img src="/assets/editar.png" alt="Editar">
                            </a>
                            <form action="/Platos/Delete/2" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar este plato?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png" alt="Eliminar">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>PL-003</td>
                    <td>Suspiro a la limeña</td>
                    <td>S/ 12.00</td>
                    <td>Postre</td>
                    <td class="status-red">INACTIVO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Platos/Edit/3" class="action-btn" title="Editar">
                                <img src="/assets/editar.png" alt="Editar">
                            </a>
                            <form action="/Platos/Delete/3" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar este plato?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png" alt="Eliminar">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        <div class="page-pill">‹</div>
        <div class="page-pill active">1</div>
        <div class="page-pill">2</div>
        <div class="page-pill">3</div>
        <div class="page-pill">›</div>
    </div>
</div>