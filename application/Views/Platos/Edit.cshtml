
@model application.Dtos.PlatoDto
@{
    ViewData["Title"] = "Editar Plato";
}

<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Editar Plato</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="form-panel">
        <input type="hidden" asp-for="id" />

        <div class="form-grid">
            <div class="field-group">
                <label>Nombre</label>
                <input type="text" class="form-input" asp-for="nombre" value="@Model.nombre" />
            </div>
            <div class="field-group">
                <label>Precio</label>
                <input type="number" step="0.01" class="form-input" asp-for="precio" value="@Model.precio" />
            </div>
            <div class="field-group">
                <label>Categoría</label>
                <select class="form-select" asp-for="categoria">
                    <option value="Entrada">Entrada</option>
                    <option value="Fondo" selected>Fondo</option>
                    <option value="Bebida">Bebida</option>
                    <option value="Postre">Postre</option>
                </select>
            </div>
            <div class="field-group">
                <label>Estado</label>
                <select class="form-select" asp-for="estado">
                    <option value="ACTIVO" selected>ACTIVO</option>
                    <option value="INACTIVO">INACTIVO</option>
                    <option value="AGOTADO">AGOTADO</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Actualizar</button>
            <a href="/Platos/Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>