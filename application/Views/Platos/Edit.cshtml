
@model application.Dtos.PlatoDto
@{
    ViewData["Title"] = "Editar Plato";
}

<div class="pedidos-form-card">
    <div class="page-top pedidos-page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Editar Plato</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="pedidos-form">
        <input type="hidden" asp-for="id" />

        <div class="pedidos-form-grid">
            <div class="pedidos-form-field">
                <label class="pedidos-filter-label">Nombre</label>
                <input type="text" class="pedidos-filter-input" asp-for="nombre" value="@Model.nombre" />
                <span asp-validation-for="nombre" class="text-danger"></span>
            </div>
            <div class="pedidos-form-field">
                <label class="pedidos-filter-label">Precio</label>
                <input type="number" step="0.01" class="pedidos-filter-input" asp-for="precio" value="@Model.precio" />
                <span asp-validation-for="precio" class="text-danger"></span>
            </div>
            <div class="pedidos-form-field">
                <label class="pedidos-filter-label">Categoría</label>
                <select class="pedidos-filter-select" asp-for="categoria">
                    @foreach (var categoria in Enum.GetValues<CategoriaPlatoEnum>())
                    {
                        if (categoria == Model.categoria)
                        {
                            <option value="@categoria" selected>@categoria</option>
                        }
                        else
                        {
                            <option value="@categoria">@categoria</option>
                        }
                    }
                </select>
                <span asp-validation-for="categoria" class="text-danger"></span>
            </div>
            <div class="pedidos-form-field">
                <label class="pedidos-filter-label">Estado</label>
                <select class="pedidos-filter-select" asp-for="estado">
                    @foreach (var estado in Enum.GetValues<EstadoPlatoEnum>())
                    {
                        if (estado == Model.estado)
                        {
                            <option value="@estado" selected>@estado</option>
                        }
                        else
                        {
                            <option value="@estado">@estado</option>
                        }
                    }
                </select>
                <span asp-validation-for="estado" class="text-danger"></span>
            </div>
        </div>

        <div class="pedidos-filter-actions pedidos-form-actions">
            <button type="submit" class="pedidos-filter-btn">Actualizar</button>
            <a href="/Platos/Index" class="pedidos-filter-btn pedidos-filter-link-btn pedidos-filter-btn-secondary">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}