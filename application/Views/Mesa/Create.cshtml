<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="assets/rombo.png" class="page-mark">
            <h1 class="page-title">Nueva Mesa</h1>
        </div>
    </div>

    <form class="form-panel">
        <div class="form-grid">
            <div class="field-group">
                <label>Capacidad</label>
                <input type="number" class="form-input" placeholder="Ej: 4, 6, 8" />
            </div>
            <div class="field-group">
                <label>Número de Piso</label>
                <input type="number" class="form-input" placeholder="Ej: 1, 2, 3" />
            </div>
            <div class="field-group">
                <label>Estado</label>
                <select class="form-select">
                    <option value="">-- Seleccionar --</option>
                    <option value="LIBRE">LIBRE</option>
                    <option value="OCUPADO">OCUPADO</option>
                    <option value="RESERVADO">RESERVADO</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Guardar</button>
            <a href="/Mesa/Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>
