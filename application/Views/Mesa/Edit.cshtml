@model application.Dtos.MesaDto
@{
    ViewData["Title"] = "Editar Mesa";
}
<div class="content-card form-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Editar Mesa</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="form-panel">
        <div class="form-grid">
            <div class="field-group">
                <label>Capacidad</label>
                <input type="number" asp-for="capacidad" value="@Model.capacidad" class="form-input" />
            </div>
            <div class="field-group">
                <label>Número de Piso</label>
                <input type="number" asp-for="numeroPiso" value="@Model.numeroPiso" class="form-input" />
            </div>
            <div class="field-group">
                <label>Estado</label>
                <select class="form-select" asp-for="estado">
                    <option value="">-- Seleccionar --</option>
                    <option value="LIBRE" selected>LIBRE</option>
                    <option value="OCUPADO">OCUPADO</option>
                    <option value="RESERVADO">RESERVADO</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn">Actualizar</button>
            <a href="/Mesa/Index" class="secondary-btn">Volver</a>
        </div>
    </form>
</div>
