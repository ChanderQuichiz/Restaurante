@model application.Dtos.MesaVM

@{
  ViewData["Title"] = "Mesa";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Mesas</h1>
        </div>
        <a href="/Mesa/Create" class="primary-btn">Nueva mesa</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" placeholder="Buscar por código" />
        </div>
        <div class="filter-box">
            <label>Piso</label>
            <select class="select-pill" name="piso">
                <option>Todos</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Estado</label>
            <select class="select-pill" name="estado">
                <option>Todos</option>
                <option>LIBRE</option>
                <option>OCUPADO</option>
                <option>RESERVADO</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Capacidad</th>
                    <th>Piso</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mesa in Model.mesas)
                {
                    <tr>
                        <td>@mesa.id</td>
                        <td>@mesa.capacidad</td>
                        <td>@mesa.numeroPiso</td>
                        <td class="status-occupied">@mesa.estado</td>
                    <td>
                        <div class="action-buttons">
                             <a href="@Url.Action("Edit", "Mesa", new { id = mesa.id })" class="action-btn" title="Editar">  
                                <img src="/assets/editar.png" alt="Editar">
                            </a>
                            <a href="@Url.Action("Delete", "Mesa", new { id = mesa.id })" class="action-btn form-delete-btn" title="Eliminar">
                                <img src="/assets/eliminar.png" alt="Eliminar">
                            </a>
                        </div>
                    </td>
                </tr>
                }

            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        @if (Model.page > 1)
        {
            <a asp-action="Index" asp-route-page="@(Model.page - 1)" class="page-pill">‹</a>
        }
        else
        {
            <div class="page-pill">‹</div>
        }

        @for (int i = 1; i <= Model.totalPages; i++)
        {
            if (i == Model.page)
            {
                <a asp-action="Index" asp-route-page="@i" class="page-pill active">@i</a>
            }
            else
            {
                <a asp-action="Index" asp-route-page="@i" class="page-pill">@i</a>
            }
        }

        @if (Model.page < Model.totalPages)
        {
            <a asp-action="Index" asp-route-page="@(Model.page + 1)" class="page-pill">›</a>
        }
        else
        {
            <div class="page-pill">›</div>
        }
    </div>
</div>


