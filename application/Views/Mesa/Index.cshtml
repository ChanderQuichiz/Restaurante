@using Microsoft.EntityFrameworkCore.Metadata.Internal
@{
  ViewData["Title"] = "Mesa";
}

<div class="content-card">
    <div class="page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Mesas</h1>
        </div>
        <a href="/Mesa/Create" class="primary-btn">Nueva mesa</a>
    </div>

    <form method="get" class="filters-grid">
        <div class="filter-box">
            <label>Buscar</label>
            <input type="text" name="buscar" class="input-pill" placeholder="Buscar por código" />
        </div>
        <div class="filter-box">
            <label>Piso</label>
            <select class="select-pill" name="piso">
                <option>Todos</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Estado</label>
            <select class="select-pill" name="estado">
                <option>Todos</option>
                <option>LIBRE</option>
                <option>OCUPADO</option>
                <option>RESERVADO</option>
            </select>
        </div>
        <div class="filter-box">
            <label>Acción</label>
            <button type="submit" class="primary-btn filter-submit-btn">Filtrar</button>
        </div>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Capacidad</th>
                    <th>Piso</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>E2D08A</td>
                    <td>30</td>
                    <td>2</td>
                    <td class="status-occupied">OCUPADO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Mesa/Edit/1" class="action-btn" title="Editar">
                                <img src="/assets/editar.png">
                            </a>
                            <form action="/Mesa/Delete/1" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar esta mesa?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>A1F03C</td>
                    <td>4</td>
                    <td>1</td>
                    <td class="status-free">LIBRE</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Mesa/Edit/2" class="action-btn" title="Editar">
                                <img src="/assets/editar.png">
                            </a>
                            <form action="/Mesa/Delete/2" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar esta mesa?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>B9K12X</td>
                    <td>6</td>
                    <td>3</td>
                    <td class="status-occupied">OCUPADO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Mesa/Edit/3" class="action-btn" title="Editar">
                                <img src="/assets/editar.png">
                            </a>
                            <form action="/Mesa/Delete/3" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar esta mesa?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>C4M77Z</td>
                    <td>8</td>
                    <td>1</td>
                    <td>RESERVADO</td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Mesa/Edit/4" class="action-btn" title="Editar">
                                <img src="/assets/editar.png">
                            </a>
                            <form action="/Mesa/Delete/4" method="post" class="inline-form" onsubmit="return confirm('¿Está seguro que desea eliminar esta mesa?');">
                                <button type="submit" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png">
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        <div class="page-pill">‹</div>
        <div class="page-pill active">1</div>
        <div class="page-pill">2</div>
        <div class="page-pill">3</div>
        <div class="page-pill">›</div>
    </div>
</div>


