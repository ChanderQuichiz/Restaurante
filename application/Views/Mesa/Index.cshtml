@model application.Dtos.MesaVM

@{
    ViewData["Title"] = "Mesa";
}

<div class="content-card">
    <div class="page-top pedidos-page-top">
        <div class="page-title-wrap">
            <img src="/assets/rombo.png" class="page-mark">
            <h1 class="page-title">Gestión de Mesas</h1>
        </div>
    </div>

    <form method="get">
        <div class="pedidos-filters-row">
            <div class="pedidos-filter-item pedidos-filter-buscar">
                <label class="pedidos-filter-label">Buscar</label>
                <input type="text" name="codigo" value="@(Model.filtros.codigo?.ToString() ?? string.Empty)" class="pedidos-filter-input" placeholder="Buscar por código" />
            </div>

            <div class="pedidos-filter-item pedidos-filter-estado">
                <label class="pedidos-filter-label">Piso</label>
                <select class="pedidos-filter-select" name="piso">
                    <option value="">Todos</option>
                    @foreach (var piso in Enum.GetValues<PisoMesaEnum>())
                    {
                        if (Model.filtros.piso == piso)
                        {
                            <option value="@((int)piso)" selected>@((int)piso)</option>
                        }
                        else
                        {
                            <option value="@((int)piso)">@((int)piso)</option>
                        }
                    }
                </select>
            </div>

            <div class="pedidos-filter-item pedidos-filter-estado">
                <label class="pedidos-filter-label">Estado</label>
                <select class="pedidos-filter-select" name="estado">
                    <option value="">Todos</option>
                    @foreach (var estado in Enum.GetValues<EstadoMesaEnum>())
                    {
                        if (Model.filtros.estado == estado)
                        {
                            <option value="@estado" selected>@estado</option>
                        }
                        else
                        {
                            <option value="@estado">@estado</option>
                        }
                    }
                </select>
            </div>

            <div class="pedidos-filter-actions">
                <button type="submit" class="pedidos-filter-btn">Filtrar</button>
                <a href="/Mesa/Create" class="pedidos-filter-btn pedidos-filter-link-btn">Nueva mesa</a>
            </div>
        </div>
    </form>

    <div class="pedidos-table-card">
        <table class="pedidos-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Capacidad</th>
                    <th>Piso</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mesa in Model.mesas)
                {
                    <tr>
                        <td>@mesa.id</td>
                        <td>@mesa.capacidad</td>
                        <td>@mesa.numeroPiso</td>
                        <td class="status-occupied">@mesa.estado</td>
                        <td>
                            <div class="action-buttons">
                                <a href="@Url.Action("Edit", "Mesa", new { id = mesa.id })" class="action-btn" title="Editar">
                                    <img src="/assets/editar.png" alt="Editar">
                                </a>
                                <a href="@Url.Action("Delete", "Mesa", new { id = mesa.id })" class="action-btn form-delete-btn" title="Eliminar">
                                    <img src="/assets/eliminar.png" alt="Eliminar">
                                </a>
                            </div>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

    <div class="pagination-mock">
        @if (Model.page > 1)
        {
            <a asp-action="Index"
               asp-route-page="@(Model.page - 1)"
                asp-route-codigo="@(Model.filtros.codigo?.ToString() ?? string.Empty)"
                asp-route-piso="@(Model.filtros.piso.HasValue ? ((int)Model.filtros.piso.Value).ToString() : string.Empty)"
                asp-route-estado="@(Model.filtros.estado?.ToString() ?? string.Empty)"
               class="page-pill">‹</a>
        }
        else
        {
            <div class="page-pill">‹</div>
        }

        @for (int i = 1; i <= Model.totalPages; i++)
        {
            if (i == Model.page)
            {
                <a asp-action="Index"
                   asp-route-page="@i"
                     asp-route-codigo="@(Model.filtros.codigo?.ToString() ?? string.Empty)"
                     asp-route-piso="@(Model.filtros.piso.HasValue ? ((int)Model.filtros.piso.Value).ToString() : string.Empty)"
                     asp-route-estado="@(Model.filtros.estado?.ToString() ?? string.Empty)"
                   class="page-pill active">@i</a>
            }
            else
            {
                <a asp-action="Index"
                   asp-route-page="@i"
                     asp-route-codigo="@(Model.filtros.codigo?.ToString() ?? string.Empty)"
                     asp-route-piso="@(Model.filtros.piso.HasValue ? ((int)Model.filtros.piso.Value).ToString() : string.Empty)"
                     asp-route-estado="@(Model.filtros.estado?.ToString() ?? string.Empty)"
                   class="page-pill">@i</a>
            }
        }

        @if (Model.page < Model.totalPages)
        {
            <a asp-action="Index"
               asp-route-page="@(Model.page + 1)"
                asp-route-codigo="@(Model.filtros.codigo?.ToString() ?? string.Empty)"
                asp-route-piso="@(Model.filtros.piso.HasValue ? ((int)Model.filtros.piso.Value).ToString() : string.Empty)"
                asp-route-estado="@(Model.filtros.estado?.ToString() ?? string.Empty)"
               class="page-pill">›</a>
        }
        else
        {
            <div class="page-pill">›</div>
        }
    </div>
</div>


